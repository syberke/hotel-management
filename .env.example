# Database PostgreSQL
DATABASE_URL="postgresql://hotel_admin:change-me@localhost:5432/hotel_management?schema=public"

# Gunakan nilai acak yang panjang di production
JWT_SECRET="replace-with-a-long-random-secret"

# Kredensial SMTP Gmail. Gunakan App Password, bukan password akun utama.
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-google-app-password"

# URL publik aplikasi. Endpoint verifikasi juga memakai origin request sebagai fallback.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
